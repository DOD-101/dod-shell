        <mxCell id="9mI5q9PQoPeVo3vNYNOv-20" value="update_state(&amp;amp;self, SystemStateData)&amp;nbsp;" style="whiteSpace=wrap;html=1;fontSize=9;" parent="9mI5q9PQoPeVo3vNYNOv-21" vertex="1">
          <mxGeometry y="60" width="97" height="60" as="geometry" />
        </mxCell>
        <mxCell id="9mI5q9PQoPeVo3vNYNOv-24" value="Dbus&amp;nbsp;&lt;div&gt;Interface&lt;/div&gt;" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;" parent="1" vertex="1">
          <mxGeometry x="1483" y="1639" width="80" height="80" as="geometry" />
        </mxCell>
        <mxCell id="9mI5q9PQoPeVo3vNYNOv-25" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;startArrow=classic;startFill=1;" parent="1" source="9mI5q9PQoPeVo3vNYNOv-12" target="9mI5q9PQoPeVo3vNYNOv-24" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="9mI5q9PQoPeVo3vNYNOv-26" value="as" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" parent="9mI5q9PQoPeVo3vNYNOv-25" vertex="1" connectable="0">
